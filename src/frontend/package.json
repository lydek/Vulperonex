{
  "name": "@vulperonex/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "vitest run --coverage",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "oxlint --config oxlint.json",
    "vue-tsc": "vue-tsc"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.0",
    "@unocss/reset": "^66.0.0",
    "pinia": "^3.0.0",
    "primevue": "^4.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.0.0",
    "oxlint": "^0.16.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.8.0",
    "unocss": "^66.0.0",
    "vite": "^7.3.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  },
  "simple-git-hooks": {
    "commit-msg": "src/frontend/node_modules/.bin/commitlint --config src/frontend/commitlint.config.cjs --edit $1"
  }
}
