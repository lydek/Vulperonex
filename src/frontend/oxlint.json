{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "vue/no-v-html": "error"
  },
  "ignorePatterns": [
    "coverage/**",
    "dist/**",
    "public/overlay/libs/**",
    "public/overlay/js/**",
    "../Hosts/Vulperonex.Web/wwwroot/**"
  ]
}
