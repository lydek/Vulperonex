{
  "name": "Phase 7 sample - shoutout lookup",
  "eventTypeKey": "user.message",
  "isEnabled": true,
  "priority": 90,
  "trigger": {
    "eventTypeKey": "user.message",
    "filter": {
      "platform": "twitch"
    },
    "matchCondition": "Trigger.MessageText.StartsWith('!so ')"
  },
  "conditions": [],
  "actions": [
    {
      "type": "lookupTwitchUser",
      "userId": "{Member.UserId}",
      "outputVariable": "Target"
    },
    {
      "type": "stopIf",
      "condition": "Step.Target.DisplayName == ''"
    },
    {
      "type": "shoutout",
      "targetLogin": "{Step.Target.Login}"
    },
    {
      "type": "sendChatMessage",
      "targetPlatform": "twitch",
      "template": "Go follow {Step.Target.DisplayName}: {Step.Target.Description}"
    }
  ],
  "onFailureSteps": [
    {
      "type": "sendChatMessage",
      "targetPlatform": "twitch",
      "template": "Shoutout failed: {Failure.ErrorMessage}"
    }
  ],
  "throttle": {
    "maxConcurrent": 1,
    "cooldownSeconds": 30,
    "perUserCooldown": false,
    "perUserCooldownSeconds": 0
  },
  "timeoutSeconds": 20
}
